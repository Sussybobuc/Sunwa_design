{
  "name": "sunwa-design",
  "version": "1.0.0",
  "private": true,
  "description": "Website CÔNG TY TNHH MTV Thiết kế và Xây dựng Sunwa — Đà Nẵng",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
