# Mail config for the quote-form backend (lib/mailer.js).
# Copy to .env next to server.js and fill in real values. NEVER commit .env.
#
# Auth is OAuth2-first: if the three OAUTH_* values are set, they are used;
# otherwise SMTP_PASS (Gmail App Password) is the fallback.
# GMAIL_USER / GMAIL_CLIENT_ID / GMAIL_CLIENT_SECRET / GMAIL_REFRESH_TOKEN
# are accepted aliases for SMTP_USER / OAUTH_*.

# Sending Gmail address (required)
SMTP_USER=you@gmail.com

# Gmail OAuth2 (preferred — see docs/run-and-deploy.md §2.3 to obtain)
OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=
OAUTH_REFRESH_TOKEN=

# Fallback: 16-char Gmail App Password (only used when OAUTH_* are unset)
# SMTP_PASS=

# Where leads arrive (default: Sunwa.design@gmail.com)
TO_EMAIL=Sunwa.design@gmail.com

# SMTP endpoint (defaults shown)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Client portal (tra cứu hồ sơ) session signing key — any long random string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Where the daily health check (deploy/healthcheck.js) sends failure alerts
# and the Monday all-OK summary. No emails are sent if unset.
HEALTH_ALERT_EMAIL=

# Server port (default 3000)
# PORT=3000
